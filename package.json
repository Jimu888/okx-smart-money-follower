{
  "name": "smart-money-follower",
  "version": "1.0.0",
  "description": "多智能钱包自动跟单系统 - Multi Smart Money Wallet Following System",
  "main": "src/index.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "nodemon backend/src/index.js",
    "start:frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon --inspect backend/src/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint backend/src frontend/src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint backend/src frontend/src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "install:all": "npm install && cd frontend && npm install",
    "clean": "rimraf node_modules frontend/node_modules backend/dist frontend/build",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "smart-money",
    "crypto",
    "trading",
    "defi",
    "automation",
    "web3",
    "blockchain",
    "following",
    "meme-coins"
  ],
  "author": {
    "name": "Smart Money Team",
    "email": "hello@smartmoney.tools",
    "url": "https://github.com/jimu888/smart-money-follower"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimu888/smart-money-follower.git"
  },
  "bugs": {
    "url": "https://github.com/jimu888/smart-money-follower/issues"
  },
  "homepage": "https://github.com/jimu888/smart-money-follower#readme",
  "dependencies": {
    "@solana/spl-token": "^0.3.9",
    "@solana/web3.js": "^1.87.6",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.8.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^6.0.1",
    "node-cron": "^3.0.3",
    "rate-limiter-flexible": "^5.0.3",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "funding": {
    "type": "crypto",
    "url": "https://github.com/jimu888/smart-money-follower#-赞助"
  }
}
