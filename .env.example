# =====================================================
# Smart Money Follower Configuration
# =====================================================
# 
# 🚨 重要提醒:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的真实API信息和钱包地址
# 3. 永远不要将 .env 文件上传到Git仓库
# 4. 建议使用测试网或小额资金开始
# =====================================================

# ===== OKX API 配置 (必需) =====
# 获取地址: https://web3.okx.com/build/docs/getting-started
# 需要权限: 读取市场数据、执行交易

OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ===== 钱包配置 (必需) =====
# 支持多链钱包，建议使用专门的交易钱包
# ⚠️ 警告: 私钥泄露将导致资金损失

# 主钱包地址 (用于接收资金和执行交易)
WALLET_ADDRESS=your_wallet_address_here

# 钱包私钥 (用于自动签名交易)
# 格式: 0x开头的64位十六进制字符串 (以太坊系)
# 格式: Base58编码字符串 (Solana)
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# ===== 跟单配置 (可选，有默认值) =====

# 每次跟单金额 (USDC)
FOLLOW_AMOUNT=100

# 最少触发钱包数量 (2-10)
MIN_TRIGGER_COUNT=3

# 最大滑点容忍度 (百分比: 1-20)
MAX_SLIPPAGE=5

# 检查间隔 (毫秒: 建议10000-60000)
CHECK_INTERVAL=30000

# ===== 安全配置 (可选) =====

# 每日最大交易次数
MAX_DAILY_TRADES=20

# 交易冷却期 (毫秒)
COOLDOWN_PERIOD=300000

# 最小流动性要求 (USD)
MIN_LIQUIDITY=10000

# 最小持有者数量
MIN_HOLDERS=100

# ===== 支持的区块链 =====
# 逗号分隔，不带空格
# 支持: ethereum,base,bsc,arbitrum,polygon,xlayer,solana

SUPPORTED_CHAINS=solana,base,ethereum

# ===== 通知配置 (可选) =====

# Telegram Bot通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook通知
DISCORD_WEBHOOK_URL=

# Email通知 (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=

# ===== 高级配置 (可选) =====

# API请求超时 (毫秒)
API_TIMEOUT=30000

# 日志级别: error, warn, info, debug
LOG_LEVEL=info

# 数据库文件路径
DB_PATH=./data/trades.json

# 备份间隔 (小时)
BACKUP_INTERVAL=24

# 开发模式 (true/false)
DEV_MODE=false

# 测试模式 (true/false - 不执行真实交易)
TEST_MODE=true

# ===== 示例配置 =====
# 
# OKX_API_KEY=1a2b3c4d-5e6f-7g8h-9i0j-k1l2m3n4o5p6
# OKX_SECRET_KEY=A1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6Q7R8S9T0
# OKX_PASSPHRASE=MySecurePassword123!
# WALLET_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
# WALLET_PRIVATE_KEY=0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890
# FOLLOW_AMOUNT=50
# MIN_TRIGGER_COUNT=2
# MAX_SLIPPAGE=3
# CHECK_INTERVAL=30000